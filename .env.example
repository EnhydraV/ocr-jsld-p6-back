# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Configuration
# Utilisé tel quel pour une instance MongoDB locale (npm run start:dev).
# Avec Docker Compose, cette valeur est ignorée et reconstruite à partir de DB_USER/DB_PASSWORD/DB_NAME.
DB_NAME=workshopsdb
DB_USER=mongouser
DB_PASSWORD=mongopassword

# CORS Configuration
CORS_ORIGIN=http://localhost
